# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com credenciais reais.

# ---- Oracle Database ----
ORACLE_PASSWORD=troque_para_senha_segura

# ---- JWT ----
# Gere uma string hex aleatória de 64 chars:
#   openssl rand -hex 32
JWT_SECRET_KEY=troque_para_chave_secreta_jwt_minimo_32_caracteres
