# Oracle Database Connection
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SID=XEPDB1
ORACLE_USER=CPTM
ORACLE_PASSWORD=root

# Connection String (Alternative - use this if you prefer full string)
# CONNECTION_STRING=Data Source=localhost:1521/XEPDB1;User ID=CPTM;Password=root;

# ASP.NET Core Environment
ASPNETCORE_ENVIRONMENT=Development

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here_min_32_characters
JWT_ISSUER=CPTMBackend
JWT_AUDIENCE=CPTMApp
JWT_EXPIRATION_MINUTES=60

# API Configuration
API_PORT=5000
API_HTTPS_PORT=5001

# Logging
LOG_LEVEL=Information

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# Email Configuration (Optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# Database Backup (Optional)
# BACKUP_PATH=/backups
# BACKUP_SCHEDULE=daily
